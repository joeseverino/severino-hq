# Copy to .env in production and fill in real values. Never commit .env.

# Core security ----------------------------------------------------------------
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Comma-separated hostnames the app will answer for. List EVERY hostname
# clients actually use, or Django returns 400 "Disallowed Host". Set this to
# whatever your reverse proxy / DNS rewrite serves (e.g. hq.example.com).
DJANGO_ALLOWED_HOSTS=hq.example.com,127.0.0.1

# If you front the app with Caddy/Nginx/NPM on https, list every full origin
# here — scheme + host (no path), one per entry the browser will use.
DJANGO_CSRF_TRUSTED_ORIGINS=https://hq.example.com

# TLS / cookie security --------------------------------------------------------
DJANGO_BEHIND_TLS_PROXY=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_HSTS_SECONDS=0           # set to 31536000 only after you've verified TLS

# Time zone --------------------------------------------------------------------
DJANGO_TIME_ZONE=America/New_York

# Storage paths ----------------------------------------------------------------
# All three should live OUTSIDE the application code directory in production.
SEVERINO_DATABASE_PATH=/var/lib/severino-hq/severino.sqlite3
SEVERINO_MEDIA_ROOT=/var/lib/severino-hq/media
SEVERINO_EXPORTS_ROOT=/var/lib/severino-hq/exports
DJANGO_STATIC_ROOT=/var/lib/severino-hq/staticfiles

# Branding ---------------------------------------------------------------------
SEVERINO_SITE_NAME=Severino HQ

# Pocket ID / OIDC SSO ---------------------------------------------------------
# Pocket ID callback URL:
# https://hq.example.com/oidc/callback/
SEVERINO_OIDC_ENABLED=0
SEVERINO_OIDC_ISSUER=https://sso.jseverino.com
SEVERINO_OIDC_CLIENT_ID=
SEVERINO_OIDC_CLIENT_SECRET=
# Optional fallback for providers that emit email; Pocket ID access uses groups.
SEVERINO_OIDC_ALLOWED_EMAILS=
SEVERINO_OIDC_ALLOWED_GROUPS=admins
SEVERINO_OIDC_CREATE_USER=1

# Cloudflare D1 ----------------------------------------------------------------
# Read/write access to the jseverino.com contact-form submissions database.
# CLOUDFLARE_API_TOKEN: create a token with the "D1 Edit" permission.
# CLOUDFLARE_D1_DATABASE_ID is the jseverino-contact database id (not secret).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=53ad6f75-644d-44b1-a0b4-04261f9335db
CLOUDFLARE_API_TOKEN=
